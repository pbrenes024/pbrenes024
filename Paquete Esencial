/* HEADER */
header { background: var(--dark); padding: 1.25rem 2rem; display: flex; justify-content: space-between; align-items: center; }
header img { height: 50px; width: auto; }
.back-btn { color: rgba(255,255,255,0.6); text-decoration: none; font-size: 0.75rem; letter-spacing: 0.2em; text-transform: uppercase; transition: color 0.3s; }
.back-btn:hover { color: var(--orange); }

/* HERO */
.pkg-hero { background: linear-gradient(135deg, var(--dark) 0%, var(--dark-mid) 100%); padding: 5rem 2rem; text-align: center; position: relative; overflow: hidden; }
.pkg-hero::before { content: ''; position: absolute; inset: 0; background: radial-gradient(ellipse 80% 60% at 50% 50%, rgba(232,133,26,0.08) 0%, transparent 70%); }
.pkg-badge { display: inline-block; border: 1px solid var(--orange); color: var(--orange); font-size: 0.65rem; letter-spacing: 0.35em; text-transform: uppercase; padding: 0.4rem 1.5rem; margin-bottom: 2rem; position: relative; }
.pkg-hero h1 { font-family: 'Cormorant Garamond', serif; font-size: clamp(2rem, 5vw, 3.5rem); font-weight: 300; color: #fff; line-height: 1.2; position: relative; }
.pkg-hero h1 em { font-style: italic; color: var(--gold-light); }
.pkg-hero p { color: rgba(255,255,255,0.5); font-size: 0.9rem; max-width: 550px; margin: 1.5rem auto 0; line-height: 1.9; position: relative; }
.pkg-hero::after { content: ''; position: absolute; bottom: 0; left: 0; right: 0; height: 4px; background: linear-gradient(to right, transparent, var(--orange), transparent); }

/* PHOTO STRIP */
.photo-strip { display: grid; grid-template-columns: repeat(4, 1fr); gap: 0.5rem; max-width: 1100px; margin: 0 auto; padding: 2rem 2rem 0; }
.photo-strip-item { aspect-ratio: 4/3; overflow: hidden; background: var(--dark-mid); }
.photo-strip-item img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.5s; opacity: 0.85; }
.photo-strip-item:hover img { transform: scale(1.05); opacity: 1; }

/* MAIN CONTENT */
.pkg-content { display: grid; grid-template-columns: 1fr 380px; gap: 4rem; max-width: 1100px; margin: 0 auto; padding: 4rem 2rem 5rem; }

/* INCLUDES */
.includes-title { font-family: 'Cormorant Garamond', serif; font-size: 1.8rem; font-weight: 300; color: var(--dark); margin-bottom: 0.5rem; }
.includes-subtitle { font-size: 0.8rem; color: var(--text-light); letter-spacing: 0.1em; margin-bottom: 2.5rem; }
.includes-list { list-style: none; }
.includes-item { display: flex; align-items: flex-start; gap: 1rem; padding: 1rem 0; border-bottom: 1px solid rgba(232,133,26,0.1); }
.includes-item:last-child { border-bottom: none; }
.item-icon { font-size: 1.3rem; flex-shrink: 0; width: 36px; text-align: center; }
.item-text strong { display: block; font-size: 0.88rem; font-weight: 500; color: var(--dark); margin-bottom: 0.2rem; }
.item-text span { font-size: 0.8rem; color: var(--text-light); line-height: 1.6; }

/* SIDEBAR */
.pkg-sidebar { position: sticky; top: 2rem; align-self: start; }
.info-card { background: var(--dark); padding: 2.5rem; margin-bottom: 1.5rem; }
.info-card-title { font-family: 'Cormorant Garamond', serif; font-size: 1.4rem; color: #fff; margin-bottom: 1.5rem; padding-bottom: 1rem; border-bottom: 1px solid rgba(232,133,26,0.3); }
.info-row { display: flex; justify-content: space-between; align-items: center; padding: 0.6rem 0; border-bottom: 1px solid rgba(255,255,255,0.06); }
.info-row:last-child { border-bottom: none; }
.info-row span:first-child { font-size: 0.78rem; letter-spacing: 0.1em; color: rgba(255,255,255,0.4); text-transform: uppercase; }
.info-row span:last-child { font-size: 0.88rem; color: rgba(255,255,255,0.8); text-align: right; }
.cta-card { background: var(--orange); padding: 2.5rem; text-align: center; }
.cta-card p { color: rgba(255,255,255,0.85); font-size: 0.85rem; margin-bottom: 1.5rem; line-height: 1.7; }
.cta-btn { display: block; background: var(--dark); color: #fff; text-decoration: none; padding: 1rem; font-size: 0.78rem; letter-spacing: 0.25em; text-transform: uppercase; font-weight: 500; transition: all 0.3s; margin-bottom: 0.75rem; }
.cta-btn:hover { background: var(--dark-mid); transform: translateY(-2px); }
.cta-btn.secondary { background: transparent; border: 1px solid rgba(255,255,255,0.5); color: #fff; }
.cta-btn.secondary:hover { background: rgba(255,255,255,0.1); }

/* RESTRICTIONS */
.restrictions { background: #fff; padding: 5rem 2rem; }
.restrictions-inner { max-width: 1100px; margin: 0 auto; }
.section-tag { font-size: 0.7rem; letter-spacing: 0.4em; text-transform: uppercase; color: var(--orange); display: block; margin-bottom: 1rem; }
.section-title { font-family: 'Cormorant Garamond', serif; font-size: clamp(1.8rem, 4vw, 2.8rem); font-weight: 300; line-height: 1.1; color: var(--dark); margin-bottom: 1.5rem; }
.section-title em { font-style: italic; color: var(--orange); }
.restrictions-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5rem; margin-top: 3rem; }
.restriction-card { border: 1px solid rgba(232,133,26,0.2); padding: 1.5rem; display: flex; align-items: flex-start; gap: 1rem; }
.restriction-icon { font-size: 1.5rem; flex-shrink: 0; }
.restriction-text strong { display: block; font-size: 0.82rem; font-weight: 500; color: var(--dark); margin-bottom: 0.25rem; letter-spacing: 0.05em; }
.restriction-text span { font-size: 0.78rem; color: var(--text-light); line-height: 1.5; }

/* FAQ */
.faq { padding: 5rem 2rem; background: var(--cream); }
.faq-inner { max-width: 800px; margin: 0 auto; }
.faq-item { border-bottom: 1px solid rgba(232,133,26,0.2); overflow: hidden; }
.faq-question { width: 100%; background: none; border: none; text-align: left; padding: 1.5rem 0; font-family: 'Jost', sans-serif; font-size: 0.95rem; font-weight: 400; color: var(--dark); cursor: pointer; display: flex; justify-content: space-between; align-items: center; gap: 1rem; }
.faq-question:hover { color: var(--orange); }
.faq-icon { font-size: 1.2rem; color: var(--orange); flex-shrink: 0; transition: transform 0.3s; }
.faq-answer { max-height: 0; overflow: hidden; transition: max-height 0.4s ease; }
.faq-answer p { padding: 0 0 1.5rem; font-size: 0.88rem; color: var(--text-light); line-height: 1.9; }
.faq-item.open .faq-icon { transform: rotate(45deg); }
.faq-item.open .faq-answer { max-height: 400px; }

/* FOOTER */
footer { background: var(--dark); padding: 2.5rem; text-align: center; }
footer img { height: 65px; width: auto; margin: 0 auto 1rem; display: block; }
footer p { color: rgba(255,255,255,0.25); font-size: 0.75rem; letter-spacing: 0.15em; }

@media (max-width: 900px) {
  header { padding: 1rem 1.5rem; }
  .pkg-content { grid-template-columns: 1fr; gap: 2rem; }
  .pkg-sidebar { position: static; }
  .restrictions-grid { grid-template-columns: 1fr; }
  .photo-strip { grid-template-columns: 1fr 1fr; }
}
