.submit-btn { background: var(--gold); color: var(--dark); border: none; padding: 1rem 2.5rem; font-family: 'Jost', sans-serif; font-size: 0.75rem; letter-spacing: 0.3em; text-transform: uppercase; font-weight: 500; cursor: pointer; transition: all 0.3s; align-self: flex-start; }
