.about { background: #fff; }
.about-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 6rem; align-items: center; }
.about-image { position: relative; aspect-ratio: 4/5; background: linear-gradient(135deg, var(--dark) 0%, var(--dark-mid) 100%); overflow: hidden; }
.about-image img { width: 100%; height: 100%; object-fit: cover; opacity: 0.85; }
.about-image::after { content: ''; position: absolute; bottom: -2rem; right: -2rem; width: 150px; height: 150px; border: 1px solid var(--gold); opacity: 0.4; pointer-events: none; }
.about-text p { color: var(--text-light); line-height: 1.9; margin-bottom: 1.5rem; font-size: 0.95rem; }
